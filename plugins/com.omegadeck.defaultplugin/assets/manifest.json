{
	"Name": "OmegaDeck Default Plugin",
	"Description": "OmegaDeck built-in actions",
	"Author": "Abraham Orihuela Mayor (a-orihuela)",
	"Version": "2.12.1",
	"CodePaths": {
		"x86_64-pc-windows-msvc": "x86_64-pc-windows-msvc/bin/omegadeck-defaultplugin.exe",
		"x86_64-apple-darwin": "x86_64-apple-darwin/bin/omegadeck-defaultplugin",
		"aarch64-apple-darwin": "aarch64-apple-darwin/bin/omegadeck-defaultplugin",
		"x86_64-unknown-linux-gnu": "x86_64-unknown-linux-gnu/bin/omegadeck-defaultplugin",
		"aarch64-unknown-linux-gnu": "aarch64-unknown-linux-gnu/bin/omegadeck-defaultplugin"
	},
	"CodePathWin": "x86_64-pc-windows-msvc/bin/omegadeck-defaultplugin.exe",
	"CodePathMac": "x86_64-apple-darwin/bin/omegadeck-defaultplugin",
	"CodePathLin": "x86_64-unknown-linux-gnu/bin/omegadeck-defaultplugin",
	"Icon": "icons/plugin",
	"Category": "OmegaDeck",
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "10.11"
		},
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		},
		{
			"Platform": "linux"
		}
	],
	"Capabilities": ["switch_profile", "device_brightness"],
	"Actions": [
		{
			"Icon": "icons/runCommand",
			"Name": "Run Command",
			"Category": "Automation",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Run a shell command on key press or release",
			"UUID": "omegadeck.builtin.runcommand",
			"PropertyInspectorPath": "propertyInspector/runCommand.html"
		},
		{
			"Icon": "icons/openUrl",
			"Name": "Open URL",
			"Category": "Automation",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Open a URL in the default browser",
			"UUID": "omegadeck.builtin.openurl",
			"PropertyInspectorPath": "propertyInspector/openUrl.html"
		},
		{
			"Icon": "icons/inputSimulation",
			"Name": "Simulate Input",
			"Category": "Automation",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Simulate keyboard shortcuts or text input",
			"UUID": "omegadeck.builtin.inputsimulation",
			"PropertyInspectorPath": "propertyInspector/inputSimulation.html"
		},
		{
			"Icon": "icons/switchProfile",
			"Name": "Switch Profile",
			"Category": "Productivity",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Switch to a different profile (e.g. Games → Work)",
			"UUID": "omegadeck.builtin.switchprofile",
			"PropertyInspectorPath": "propertyInspector/switchProfile.html"
		},
		{
			"Icon": "icons/brightnessUp",
			"Name": "Brightness Up",
			"Category": "System",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Increase the Stream Deck brightness",
			"UUID": "omegadeck.builtin.brightnessup",
			"PropertyInspectorPath": "propertyInspector/brightnessUp.html"
		},
		{
			"Icon": "icons/brightnessDown",
			"Name": "Brightness Down",
			"Category": "System",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Decrease the Stream Deck brightness",
			"UUID": "omegadeck.builtin.brightnessdown",
			"PropertyInspectorPath": "propertyInspector/brightnessDown.html"
		},
		{
			"Icon": "icons/volumeUp",
			"Name": "Volume Up",
			"Category": "Media",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Increase system volume",
			"UUID": "omegadeck.builtin.volumeup"
		},
		{
			"Icon": "icons/volumeDown",
			"Name": "Volume Down",
			"Category": "Media",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Decrease system volume",
			"UUID": "omegadeck.builtin.volumedown"
		},
		{
			"Icon": "icons/volumeOn",
			"Name": "Mute",
			"Category": "Media",
			"DisableAutomaticStates": true,
			"States": [
				{ "Image": "icons/volumeOn" },
				{ "Image": "icons/mute" }
			],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Toggle system mute",
			"UUID": "omegadeck.builtin.mute"
		},
		{
			"Icon": "icons/play",
			"Name": "Play / Pause",
			"Category": "Media",
			"DisableAutomaticStates": true,
			"States": [
				{ "Image": "icons/play" },
				{ "Image": "icons/pause" }
			],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Play or pause media playback",
			"UUID": "omegadeck.builtin.playpause"
		},
		{
			"Icon": "icons/nextTrack",
			"Name": "Next Track",
			"Category": "Media",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Skip to the next media track",
			"UUID": "omegadeck.builtin.nexttrack"
		},
		{
			"Icon": "icons/prevTrack",
			"Name": "Previous Track",
			"Category": "Media",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Go back to the previous media track",
			"UUID": "omegadeck.builtin.prevtrack"
		},
		{
			"Icon": "icons/lockScreen",
			"Name": "Lock Screen",
			"Category": "System",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Lock the screen / session",
			"UUID": "omegadeck.builtin.lockscreen"
		},
		{
			"Icon": "icons/sleep",
			"Name": "Sleep",
			"Category": "System",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Suspend the computer",
			"UUID": "omegadeck.builtin.sleep"
		},
		{
			"Icon": "icons/screenshot",
			"Name": "Screenshot",
			"Category": "System",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad", "Encoder"],
			"SupportedInMultiActions": true,
			"Tooltip": "Take a screenshot",
			"UUID": "omegadeck.builtin.screenshot",
			"PropertyInspectorPath": "propertyInspector/screenshot.html"
		},
		{
			"Icon": "icons/pomodoro",
			"Name": "Pomodoro Timer",
			"Category": "Productivity",
			"States": [{ "Image": "actionDefaultImage" }],
			"Controllers": ["Keypad"],
			"SupportedInMultiActions": false,
			"Tooltip": "Pomodoro timer shown on the key. Press to start/pause, hold to reset.",
			"UUID": "omegadeck.builtin.pomodoro",
			"PropertyInspectorPath": "propertyInspector/pomodoro.html"
		}
	]
}
